theme = Catppuccin Mocha
custom-shader-animation = always
#custom-shader = ./shaders/sahaj-b/cursor_warp.glsl
#custom-shader = ./shaders/sahaj-b/ripple_cursor.glsl
custom-shader = ./shaders/KroneCorylus/cursor_blaze_tapered.glsl

macos-titlebar-style = transparent

# cursor
# maroon
cursor-color = #eba0ac
# teal
#cursor-color = #81c8be
# blue
#cursor-color = #8caaee
cursor-style = block
cursor-style-blink = false
# shell integration sends DECSCUSR sequences that override cursor-style/blink; disable it
shell-integration-features = no-cursor
